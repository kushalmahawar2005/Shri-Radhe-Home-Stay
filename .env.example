# ────────────────────────────────────────────────────────────────
#  Shri Radha Home Stay — environment variables
#  Copy this file to `.env.local` for local development.
#  On Vercel, most of these are added automatically when you connect
#  a Postgres (Neon) database and a Blob store to the project.
# ────────────────────────────────────────────────────────────────

# Public site URL (used for SEO canonical, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://shriradhahomestay.com

# ── DATABASE (Neon Postgres via Vercel) ──────────────────────────
# Create: Vercel dashboard → Storage → Create Database → Postgres (Neon).
# Then run `vercel env pull .env.local` to fill these automatically.
# The Neon integration sets DATABASE_URL (and POSTGRES_URL). Either works.
DATABASE_URL=
# Pooled/unpooled fallbacks Vercel may set — keep if present:
# POSTGRES_URL=
# DATABASE_URL_UNPOOLED=

# ── IMAGE UPLOADS (Vercel Blob) ──────────────────────────────────
# Create: Vercel dashboard → Storage → Create → Blob. Connect to project.
# `vercel env pull` fills this. Needed for admin photo uploads.
BLOB_READ_WRITE_TOKEN=

# ── ADMIN PANEL ──────────────────────────────────────────────────
# Secret used to sign the admin session cookie. Generate a long random
# string, e.g.:  openssl rand -base64 32
AUTH_SECRET=

# Initial admin account (used ONCE by `npm run db:seed` to create the
# first login). After seeding you can change the password from the panel.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-now

# ── OPTIONAL contact form fallback ───────────────────────────────
# If set, the public contact/booking forms also post here. They always
# save to the database now, so this is optional.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# ── RAZORPAY PAYMENT (Online booking advance) ────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
