# ────────────────────────────────────────────────────────────────
#  Shri Radha Home Stay — environment variables
#  The site works FULLY without any of these. They only enable the
#  OPTIONAL contact form. Copy this file to `.env.local` to use them.
# ────────────────────────────────────────────────────────────────

# Public site URL (used for SEO canonical, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=https://shriradhahomestay.com

# ---- OPTIONAL contact form ----
# Choose ONE provider. If neither is set, the contact form simply
# falls back to a WhatsApp deep link (no server needed).

# Option A) Formspree — easiest, no server code.
# Create a form at https://formspree.io and paste its endpoint here.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Option B) Resend via a Route Handler (only if you DON'T use output:'export').
# Keep this server-side secret OUT of NEXT_PUBLIC_*.
RESEND_API_KEY=
CONTACT_TO_EMAIL=stay@shriradhahomestay.com
